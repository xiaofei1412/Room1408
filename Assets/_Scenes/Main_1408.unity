    - target: {fileID: 4380983932646376613, guid: 4c1284d808983eb4089333d8c31b3e94, type: 3}
      propertyPath: itemData
      value: 
      objectReference: {fileID: 11400000, guid: 650c93173e1d8d546b256d7d93989dba, type: 2}
    - target: {fileID: 6246951784070505263, guid: 4c1284d808983eb4089333d8c31b3e94, type: 3}
      propertyPath: noteTitle
      value: FROZEN HORIZON
      objectReference: {fileID: 0}
    - target: {fileID: 6246951784070505263, guid: 4c1284d808983eb4089333d8c31b3e94, type: 3}
      propertyPath: noteContent
      value: 'The water washes nothing away.

        To find what was buried, you
        must seek the window that never opens. Where the sky is woven from oil, and
        the trees stand paralyzed in time.

        Tear away the illusion of the
        quiet landscape... the real rot festers behind the wooden frame.'
      objectReference: {fileID: 0}
