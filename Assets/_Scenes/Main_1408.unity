      value: Diary1
      objectReference: {fileID: 0}
    - target: {fileID: 5459286595269771941, guid: f10ee8f302bbdff469ca45c332397fe5, type: 3}
      propertyPath: m_TagString
      value: Untagged
      objectReference: {fileID: 0}
    - target: {fileID: 7220886751484249327, guid: f10ee8f302bbdff469ca45c332397fe5, type: 3}
      propertyPath: noteTitle
      value: October 12th - The Metronome
      objectReference: {fileID: 0}
    - target: {fileID: 7220886751484249327, guid: f10ee8f302bbdff469ca45c332397fe5, type: 3}
      propertyPath: noteContent
      value: 'It started with a ticking. Not the grandfather clock in the corner...
        the clock is dead.

        The sound is coming from inside the walls. Or
        inside my head.

        I took apart the radio. I smashed the TV. But the
        rhythm doesn''t stop. It aligns perfectly with my pulse. 1-4-0-8. 1-4-0-8.

        I
        think I cut my finger on the glass. The paper is ruined.'
      objectReference: {fileID: 0}
