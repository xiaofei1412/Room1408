  m_Script: {fileID: 11500000, guid: e2d12754d13c346428d90eee7fd68121, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Logic_NoteText
  noteTitle: THE WOODEN MAW
  noteContent: 'Time ticks, but the rot remains static.

    You seek the keys to
    your own cage, yet you ignore the wooden mouths yawning in the dark.

    Go
    to the place where the dreamer lies. Seek the twin wooden coffins stacked beside
    the bed. The left one is starving... pry it open, and see what it swallowed.'
